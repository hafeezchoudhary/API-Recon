{
    "info": {
        "name": "APILens Master Collection",
        "_postman_id": "12345678-abcd-1234-abcd-123456789abc",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "variable": [
        {
            "key": "base_url",
            "value": "https://api.example.com"
        },
        {
            "key": "api_key",
            "value": "123456789"
        },
        {
            "key": "access_token",
            "value": "token123"
        }
    ],
    "item": [
        {
            "name": "Public APIs",
            "item": [
                {
                    "name": "Get Users",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/users"
                        }
                    }
                },
                {
                    "name": "Get Products",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{base_url}}/products"
                        }
                    }
                },
                {
                    "name": "Search Users",
                    "request": {
                        "method": "GET",
                        "url": {
                            "raw": "{{base_url}}/users?page=1&limit=10&sort=name",
                            "query": [
                                {
                                    "key": "page",
                                    "value": "1"
                                },
                                {
                                    "key": "limit",
                                    "value": "10"
                                },
                                {
                                    "key": "sort",
                                    "value": "name"
                                }
                            ]
                        }
                    }
                }
            ]
        },
        {
            "name": "Authentication",
            "item": [
                {
                    "name": "Login",
                    "request": {
                        "method": "POST",
                        "auth": {
                            "type": "noauth"
                        },
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{ \"username\": \"admin\", \"password\": \"password123\" }"
                        },
                        "url": {
                            "raw": "{{base_url}}/login"
                        }
                    }
                },
                {
                    "name": "Profile",
                    "request": {
                        "method": "GET",
                        "auth": {
                            "type": "bearer"
                        },
                        "url": {
                            "raw": "{{base_url}}/profile"
                        }
                    }
                },
                {
                    "name": "Update Profile",
                    "request": {
                        "method": "PUT",
                        "auth": {
                            "type": "bearer"
                        },
                        "url": {
                            "raw": "{{base_url}}/profile"
                        }
                    }
                }
            ]
        },
        {
            "name": "API Keys",
            "item": [
                {
                    "name": "Get Metrics",
                    "request": {
                        "method": "GET",
                        "auth": {
                            "type": "apikey"
                        },
                        "header": [
                            {
                                "key": "X-API-Key",
                                "value": "{{api_key}}"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/metrics"
                        }
                    }
                }
            ]
        },
        {
            "name": "Admin",
            "item": [
                {
                    "name": "Delete User",
                    "request": {
                        "method": "DELETE",
                        "auth": {
                            "type": "basic"
                        },
                        "url": {
                            "raw": "{{base_url}}/users/1"
                        }
                    }
                },
                {
                    "name": "Nested Folder",
                    "item": [
                        {
                            "name": "Patch User",
                            "request": {
                                "method": "PATCH",
                                "auth": {
                                    "type": "oauth2"
                                },
                                "url": {
                                    "raw": "{{base_url}}/users/1"
                                }
                            }
                        }
                    ]
                }
            ]
        },
        {
            "name": "Body Examples",
            "item": [
                {
                    "name": "Register User",
                    "request": {
                        "method": "POST",
                        "body": {
                            "mode": "urlencoded",
                            "urlencoded": [
                                {
                                    "key": "username",
                                    "value": "admin"
                                },
                                {
                                    "key": "password",
                                    "value": "password123"
                                }
                            ]
                        },
                        "url": {
                            "raw": "{{base_url}}/register"
                        }
                    }
                },
                {
                    "name": "Upload Avatar",
                    "request": {
                        "method": "POST",
                        "body": {
                            "mode": "formdata",
                            "formdata": [
                                {
                                    "key": "avatar",
                                    "type": "file"
                                }
                            ]
                        },
                        "url": {
                            "raw": "{{base_url}}/upload"
                        }
                    }
                },
                {
                    "name": "Secrets Endpoint",
                    "request": {
                        "method": "POST",
                        "body": {
                            "mode": "raw",
                            "raw": "{ \"token\": \"abc123\", \"secret\": \"xyz\", \"api_key\": \"123456\" }"
                        },
                        "url": {
                            "raw": "{{base_url}}/secrets"
                        }
                    },
                    "response": [
                        {
                            "name": "Success",
                            "status": "OK",
                            "code": 200,
                            "body": "{ \"success\": true }"
                        }
                    ]
                }
            ]
        }
    ]
}